---
import { Image } from 'astro:assets';
import { aboutImage } from '../data/site';
---

<section id="about" class="grid grid-cols-2 items-center gap-[72px] bg-cream px-[7vw] py-40 max-lg:grid-cols-1 max-lg:gap-14">
  <div data-img-reveal class="relative h-[560px] overflow-hidden rounded bg-[#e7dcc8] max-lg:h-[420px]">
    <Image
      src={aboutImage}
      alt="Chef preparing fresh Indian cuisine in the India Gate kitchen"
      widths={[640, 1200]}
      sizes="(max-width: 1024px) 100vw, 50vw"
      loading="lazy"
      data-parallax
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute -right-px -bottom-px max-w-[260px] bg-brick px-[30px] py-[26px] text-cream">
      <div id="badge-count" class="font-serif text-[46px] leading-none font-semibold">25+</div>
      <div class="mt-1.5 text-[12px] tracking-[1.5px] uppercase opacity-85">years serving St. John's</div>
    </div>
  </div>

  <div data-about-copy class="relative">
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 -left-4 font-serif text-[clamp(120px,15vw,200px)] leading-none text-ink/5 select-none"
      >02</span
    >
    <div class="mb-[18px] text-[11px] font-medium tracking-[4px] uppercase text-brick">Our Story</div>
    <h2 class="m-0 mb-[26px] font-serif text-[clamp(34px,4.6vw,58px)] leading-[1.05] font-medium">
      The region's original<br />Indian kitchen
    </h2>
    <p class="m-0 mb-5 text-base leading-[1.85] font-light text-body-text">
      For more than 25 years, family-owned India Gate has served fresh, authentic Indian cuisine to
      St. John's and across Newfoundland. As the oldest Indian restaurant in the region, we're
      known for our quality and consistency, using only the freshest, most flavourful ingredients.
    </p>
    <p class="m-0 mb-[34px] text-base leading-[1.85] font-light text-body-text">
      From perfectly cooked lamb and tandoori chicken to our ever-popular naan, there's something
      for everyone — whether you're new to Indian food or a seasoned veteran. Dine-in, takeout and
      catering available.
    </p>
    <div class="flex flex-wrap gap-12">
      <div>
        <div class="font-serif text-[40px] leading-none font-semibold text-brick">Oldest</div>
        <div class="mt-1 text-[12px] tracking-[1px] uppercase text-body-muted">Indian spot in the region</div>
      </div>
      <div>
        <div class="font-serif text-[40px] leading-none font-semibold text-brick">V · GF</div>
        <div class="mt-1 text-[12px] tracking-[1px] uppercase text-body-muted">Vegan &amp; gluten-free options</div>
      </div>
    </div>
  </div>
</section>
