---
import { site, hours } from '../data/site';
import ReserveForm from './ReserveForm.astro';
---

<section id="visit" class="grid grid-cols-2 items-stretch gap-[72px] bg-dark px-[7vw] py-40 text-cream max-lg:grid-cols-1 max-lg:gap-14">
  <div data-reveal-group class="relative">
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 -left-3 font-serif text-[clamp(110px,14vw,190px)] leading-none text-cream/5 select-none"
      >04</span
    >
    <div class="mb-[18px] text-[11px] font-medium tracking-[4px] uppercase text-gold">Visit Us</div>
    <h2 class="m-0 mb-9 font-serif text-[clamp(34px,4.6vw,58px)] leading-[1.05] font-medium">
      Downtown<br />St. John's
    </h2>

    <div class="mb-9 flex flex-col gap-[26px]">
      <div>
        <div class="mb-2 text-[11px] tracking-[2px] uppercase text-gold">Address</div>
        <div class="text-[17px] leading-[1.6] font-light">{site.address[0]}<br />{site.address[1]}</div>
      </div>
      <div>
        <div class="mb-2 text-[11px] tracking-[2px] uppercase text-gold">Reservations &amp; Takeout</div>
        <div class="text-[17px] font-light">{site.phone} · {site.website}</div>
      </div>
      <div>
        <div class="mb-2.5 text-[11px] tracking-[2px] uppercase text-gold">Hours</div>
        <div class="flex flex-col gap-2">
          {
            hours.map((h) => (
              <div class="flex max-w-[340px] justify-between border-b border-cream/10 pb-2 text-[15px] font-light">
                <span>{h.day}</span>
                <span class="text-cream/70">{h.time}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="relative h-[200px] overflow-hidden rounded bg-[#1a110d]">
      <iframe
        title="India Gate location map"
        src={site.mapEmbed}
        loading="lazy"
        class="absolute inset-0 h-full w-full border-0 [filter:grayscale(0.3)_contrast(1.05)]"
      ></iframe>
    </div>
    <a
      href={site.directionsHref}
      target="_blank"
      rel="noopener"
      class="mt-4 inline-block text-[12px] tracking-[2px] uppercase text-gold no-underline transition-colors hover:text-gold-hover"
    >
      Get Directions →
    </a>
  </div>

  <ReserveForm />
</section>
