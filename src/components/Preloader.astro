<!-- Shown only when html.anim is set (see global.css); GSAP drives the counter and curtain lift -->
<div id="preloader" class="fixed inset-0 z-[100] flex-col items-center justify-center bg-dark text-cream">
  <div class="font-serif text-[34px] font-semibold tracking-[4px]">INDIA GATE</div>
  <div class="mt-2 text-[10px] tracking-[5px] uppercase text-gold">St. John's · Newfoundland</div>
  <div class="mt-8 h-px w-[220px] overflow-hidden bg-cream/15">
    <div id="preloader-bar" class="h-full w-full origin-left scale-x-0 bg-gold"></div>
  </div>
  <div id="preloader-count" class="absolute right-[7vw] bottom-10 font-serif text-6xl text-cream/60">0</div>
</div>
