---
import { faqs } from '../data/site';
---

<section id="faq" aria-labelledby="faq-heading" class="bg-cream px-[7vw] py-40">
  <div class="mx-auto max-w-[820px]">
    <div data-reveal class="mb-14 text-center">
      <div class="mb-4 text-[11px] font-medium tracking-[4px] uppercase text-brick">Good to Know</div>
      <h2 id="faq-heading" class="m-0 font-serif text-[clamp(36px,5vw,64px)] leading-none font-medium">
        Frequently Asked Questions
      </h2>
    </div>
    <div data-reveal-group>
      {
        faqs.map((f) => (
          <details class="group border-b border-ink/10 py-2">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-4 font-serif text-[22px] font-semibold text-ink [&::-webkit-details-marker]:hidden">
              {f.q}
              <span
                aria-hidden="true"
                class="faq-icon shrink-0 text-xl font-light text-gold-dark transition-transform duration-300 group-open:rotate-45"
              >
                +
              </span>
            </summary>
            <div class="faq-answer overflow-hidden">
              <p class="m-0 pb-5 text-base leading-[1.85] font-light text-body-text">{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // Animate <details> open/close; reduced-motion users keep the native toggle
  if (document.documentElement.classList.contains('anim')) {
    document.querySelectorAll<HTMLDetailsElement>('#faq details').forEach((details) => {
      const summary = details.querySelector('summary')!;
      const answer = details.querySelector<HTMLElement>('.faq-answer')!;
      const icon = details.querySelector<HTMLElement>('.faq-icon')!;
      let busy = false;

      summary.addEventListener('click', (e) => {
        e.preventDefault();
        if (busy) return;
        busy = true;

        if (details.open) {
          gsap.to(icon, { rotate: 0, duration: 0.3, ease: 'power2.inOut' });
          gsap.to(answer, {
            height: 0,
            opacity: 0,
            duration: 0.4,
            ease: 'power2.inOut',
            onComplete: () => {
              details.open = false;
              gsap.set([answer, icon], { clearProps: 'all' });
              busy = false;
            },
          });
        } else {
          details.open = true;
          gsap.fromTo(icon, { rotate: 0 }, { rotate: 45, duration: 0.3, ease: 'power2.out' });
          gsap.fromTo(
            answer,
            { height: 0, opacity: 0 },
            {
              height: 'auto',
              opacity: 1,
              duration: 0.5,
              ease: 'power2.out',
              onComplete: () => {
                gsap.set(answer, { clearProps: 'all' });
                busy = false;
              },
            }
          );
        }
      });
    });
  }
</script>
